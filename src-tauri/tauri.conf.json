{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bi-Code",
  "version": "0.1.0",
  "identifier": "com.bicode.ide",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Bi-Code",
        "width": 1280,
        "height": 800,
        "minWidth": 640,
        "minHeight": 400,
        "decorations": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
